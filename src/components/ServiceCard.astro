---
import FeatureIcon from "./FeatureIcon.astro";
import Icon from "./Icon.astro";
import type { Service } from "../data/services";

interface Props {
  service: Service;
}
const { service } = Astro.props;
---

<a
  href={`/services/${service.slug}/`}
  class="card group flex flex-col p-7 transition-shadow hover:shadow-lift md:p-8"
>
  <span
    class="inline-flex h-14 w-14 items-center justify-center rounded-xl bg-brand text-white"
  >
    <FeatureIcon name={service.icon} size={30} />
  </span>
  <h3 class="mt-5 text-xl font-bold text-navy group-hover:text-periwinkle md:text-2xl">
    {service.title}
  </h3>
  <ul class="mt-4 space-y-3">
    {
      service.bullets.map((b) => (
        <li class="flex gap-3 text-[0.975rem] leading-relaxed text-ink/80">
          <span class="mt-1 shrink-0 text-periwinkle">
            <Icon name="check" size={18} />
          </span>
          {b}
        </li>
      ))
    }
  </ul>
  <span class="mt-6 inline-flex items-center gap-2 font-semibold text-periwinkle">
    Learn more
    <Icon name="arrow-right" size={18} />
  </span>
</a>
