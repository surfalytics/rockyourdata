---
import { Image } from "astro:assets";
import heroImg from "../assets/hero/data-engineering.jpg";
import { site } from "../data/site";
import Icon from "./Icon.astro";
---

<section class="relative isolate flex min-h-[90vh] items-center overflow-hidden">
  <!-- Banner image -->
  <Image
    src={heroImg}
    alt=""
    widths={[768, 1280, 1920, 2400]}
    sizes="100vw"
    fetchpriority="high"
    loading="eager"
    class="absolute inset-0 -z-20 h-full w-full object-cover"
  />
  <!-- Dark overlay for legibility -->
  <div
    class="absolute inset-0 -z-10 bg-gradient-to-br from-paper/92 via-paper/80 to-brand/70"
    aria-hidden="true"
  >
  </div>
  <div
    class="absolute -right-24 top-1/4 -z-10 h-96 w-96 rounded-full bg-periwinkle/20 blur-3xl"
    aria-hidden="true"
  >
  </div>

  <div class="shell w-full pt-32 pb-20 md:pt-40 md:pb-28">
    <div class="max-w-3xl">
      <h1
        class="reveal text-5xl font-extrabold tracking-tight text-navy sm:text-6xl md:text-7xl"
        style="animation-delay: 60ms"
      >
        Modern data engineering that <span class="text-accent">powers your analytics</span>
      </h1>

      <p
        class="reveal mt-7 max-w-2xl text-lg leading-relaxed text-ink-soft md:text-xl"
        style="animation-delay: 140ms"
      >
        We architect and build the modern data stack — ingestion, transformation,
        and BI on the cloud — turning your raw data into a secure, scalable
        foundation your business can run on.
      </p>

      <div
        class="reveal mt-10 flex flex-col items-start gap-3 sm:flex-row sm:items-center"
        style="animation-delay: 220ms"
      >
        <a href={`mailto:${site.email}`} class="btn-primary text-base">
          Get a data services quote
          <Icon name="arrow-right" size={18} />
        </a>
        <a href="/services/" class="btn-outline text-base">
          Explore our services
        </a>
      </div>
    </div>
  </div>
</section>
