---
import { site } from "../data/site";
import Icon from "./Icon.astro";
---

<section class="relative overflow-hidden bg-paper">
  <!-- faint editorial grid, barely there -->
  <div
    class="pointer-events-none absolute inset-0 -z-10 opacity-[0.5] [background-image:linear-gradient(var(--color-line)_1px,transparent_1px),linear-gradient(90deg,var(--color-line)_1px,transparent_1px)] [background-size:64px_64px] [mask-image:radial-gradient(ellipse_at_top,black,transparent_70%)]"
    aria-hidden="true"
  >
  </div>

  <div class="shell flex flex-col items-center pt-32 pb-20 text-center md:pt-40 md:pb-28">
    <span
      class="reveal inline-flex items-center gap-2.5 rounded-full border border-line bg-mist px-4 py-1.5 text-sm font-medium text-ink-soft"
      style="animation-delay: 0ms"
    >
      <span class="h-1.5 w-1.5 rounded-full bg-accent"></span>
      Cloud analytics consulting · North America
    </span>

    <h1
      class="reveal mt-7 max-w-4xl text-5xl font-extrabold tracking-tight text-navy sm:text-6xl md:text-[5.25rem]"
      style="animation-delay: 70ms"
    >
      The data foundation your business runs on
    </h1>

    <p
      class="reveal mt-7 max-w-2xl text-lg leading-relaxed text-ink-soft md:text-xl"
      style="animation-delay: 140ms"
    >
      We use data engineering and analytics to help our clients make distinctive,
      lasting improvements in performance — turning raw data into secure, scalable
      cloud analytics.
    </p>

    <div
      class="reveal mt-10 flex flex-col items-center gap-3 sm:flex-row"
      style="animation-delay: 210ms"
    >
      <a href={`mailto:${site.email}`} class="btn-primary text-base">
        Get a data services quote
        <Icon name="arrow-right" size={18} />
      </a>
      <a href={site.surfalytics} target="_blank" rel="noopener" class="btn-outline text-base">
        Start a data career
      </a>
    </div>
  </div>
</section>
