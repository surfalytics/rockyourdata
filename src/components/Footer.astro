---
import { Image } from "astro:assets";
import logo from "../assets/logo/rockyourdata-logo.png";
import { nav, site } from "../data/site";
import { services } from "../data/services";
import SocialLinks from "./SocialLinks.astro";

const year = new Date().getFullYear();
---

<footer class="mt-24 bg-brand text-white">
  <div class="shell py-16">
    <div class="grid gap-12 md:grid-cols-2 lg:grid-cols-[1.8fr_1fr_1.2fr]">
      <!-- Brand -->
      <div>
        <Image
          src={logo}
          alt="Rock Your Data"
          height={40}
          densities={[1, 2]}
          class="h-10 w-auto brightness-0 invert"
        />
        <p class="mt-5 max-w-xs text-sm leading-relaxed text-white/70">
          {site.description}
        </p>
        <SocialLinks tone="light" class="mt-6" />
      </div>

      <!-- Nav -->
      <nav aria-label="Footer">
        <h2 class="text-sm font-semibold uppercase tracking-widest text-periwinkle-200">
          Explore
        </h2>
        <ul class="mt-4 space-y-3 text-sm text-white/80">
          {
            nav.map((item) => (
              <li>
                <a href={item.href} class="transition-colors hover:text-white">
                  {item.label}
                </a>
              </li>
            ))
          }
          <li>
            <a href={`mailto:${site.email}`} class="transition-colors hover:text-white">
              {site.email}
            </a>
          </li>
        </ul>
      </nav>

      <!-- Services -->
      <nav aria-label="Services">
        <h2 class="text-sm font-semibold uppercase tracking-widest text-periwinkle-200">
          Services
        </h2>
        <ul class="mt-4 space-y-3 text-sm text-white/80">
          {
            services.map((s) => (
              <li>
                <a href={`/services/${s.slug}/`} class="transition-colors hover:text-white">
                  {s.title}
                </a>
              </li>
            ))
          }
        </ul>
      </nav>
    </div>

    <div
      class="mt-14 flex flex-col items-start justify-between gap-3 border-t border-white/15 pt-6 text-sm text-white/60 sm:flex-row sm:items-center"
    >
      <p>&copy; {year} {site.name}. All rights reserved.</p>
      <p>
        Designed by{" "}
        <a
          href={site.designCredit.url}
          target="_blank"
          rel="noopener"
          class="underline-offset-2 hover:text-white hover:underline"
        >
          {site.designCredit.name}
        </a>
      </p>
    </div>
  </div>
</footer>
