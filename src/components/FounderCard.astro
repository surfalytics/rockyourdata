---
import { Image } from "astro:assets";
import founderPhoto from "../assets/people/founder.png";
import { founder } from "../data/founder";
import Icon from "./Icon.astro";
---

<section class="shell pt-16 md:pt-24">
  <div class="card grid gap-10 overflow-hidden p-6 md:grid-cols-[0.85fr_1.15fr] md:p-10">
    <div>
      <Image
        src={founderPhoto}
        alt="Dmitry Anoshin, founder of Rock Your Data"
        widths={[360, 600, 900]}
        sizes="(min-width: 768px) 22rem, 80vw"
        class="w-full rounded-xl border border-line object-cover"
      />
    </div>
    <div>
      <span class="eyebrow">Meet the founder</span>
      <h2 class="mt-2 text-3xl font-extrabold tracking-tight text-navy md:text-4xl">
        {founder.name}
      </h2>
      <p class="mt-1 font-medium text-periwinkle">{founder.role}</p>

      <div class="mt-5 space-y-4 leading-relaxed text-ink-soft">
        {founder.bio.map((p) => <p>{p}</p>)}
      </div>

      <ul class="mt-6 space-y-3">
        {
          founder.credentials.map((c) => (
            <li class="flex gap-3 text-[0.975rem] leading-relaxed text-ink/85">
              <span class="mt-0.5 shrink-0 text-periwinkle">
                <Icon name="check" size={20} />
              </span>
              {c}
            </li>
          ))
        }
      </ul>
    </div>
  </div>
</section>
