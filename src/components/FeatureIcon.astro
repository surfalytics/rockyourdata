---
// Consistent stroked icon set for service / value / role cards.
const paths = {
  // layered data stack
  stack: "M12 3l9 5-9 5-9-5 9-5zM3 12l9 5 9-5M3 17l9 5 9-5",
  // performance gauge / audit
  gauge: "M4 19a8 8 0 1116 0M12 19v-6m0 0l3.5-3.5",
  // certification badge
  badge: "M12 14a5 5 0 100-10 5 5 0 000 10zM8.5 13L7 22l5-2.5L17 22l-1.5-9",
  // team / users
  users: "M16 18v-2a4 4 0 00-4-4H6a4 4 0 00-4 4v2M9 8a3 3 0 100-6 3 3 0 000 6zM22 18v-2a4 4 0 00-3-3.87M16 2.13A4 4 0 0116 9.87",
  // expert (single authority figure)
  expert: "M12 11a4 4 0 100-8 4 4 0 000 8zM4 21a8 8 0 0116 0M18 4l1.5 1.5L23 2",
  // pair of hands / support
  hands: "M4 14l4-7a1.5 1.5 0 013 .8V12M20 14l-4-7a1.5 1.5 0 00-3 .8V12M4 14v3a4 4 0 004 4h8a4 4 0 004-4v-3M9 12h6",
  // collaboration / handshake
  handshake: "M8 12l3 3 2-2 3 3M2 9l4-3 5 4M22 9l-4-3-3 2.4M6 6v8M18 6v8",
  // trust / shield
  shield: "M12 3l8 3v6c0 5-3.5 8-8 9-4.5-1-8-4-8-9V6l8-3zM9 12l2 2 4-4",
  // target / client focus
  target: "M12 21a9 9 0 100-18 9 9 0 000 18zM12 16a4 4 0 100-8 4 4 0 000 8zM12 12h.01",
  // innovation / spark
  spark: "M12 3v4M12 17v4M3 12h4M17 12h4M6 6l2.5 2.5M15.5 15.5L18 18M18 6l-2.5 2.5M8.5 15.5L6 18",
} as const;

export type FeatureIconName = keyof typeof paths;

interface Props {
  name: FeatureIconName;
  size?: number;
  class?: string;
}
const { name, size = 28, class: className } = Astro.props;
---

<svg
  xmlns="http://www.w3.org/2000/svg"
  width={size}
  height={size}
  viewBox="0 0 24 24"
  fill="none"
  stroke="currentColor"
  stroke-width="1.75"
  stroke-linecap="round"
  stroke-linejoin="round"
  class={className}
  aria-hidden="true"
>
  <path d={paths[name]} />
</svg>
