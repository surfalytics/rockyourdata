---
import MarketingLayout from "../layouts/MarketingLayout.astro";
import SectionHeading from "../components/SectionHeading.astro";
import Icon from "../components/Icon.astro";
import { site } from "../data/site";
import { academyIntro, tracks, pillars } from "../data/academy";
import { stats, gains, salaries, salaryInsights } from "../data/dataAnalyst";
---

<MarketingLayout
  title="Data Academy"
  description="Surfalytics Data Academy — a mentorship-driven path to your first data job. Pick a track, follow the roadmap, and get hired."
>
  <!-- Hero -->
  <section class="bg-paper">
    <div class="shell pt-32 pb-14 text-center md:pt-40 md:pb-20">
      <span class="reveal eyebrow">Surfalytics Data Academy</span>
      <h1 class="reveal mx-auto mt-3 max-w-3xl text-4xl font-extrabold tracking-tight text-navy sm:text-5xl md:text-6xl" style="animation-delay:80ms">
        Learn data the <span class="text-accent">apprenticeship</span> way
      </h1>
      <p class="reveal mx-auto mt-6 max-w-2xl text-lg text-ink-soft" style="animation-delay:160ms">
        Rock Your Data runs its learning through Surfalytics — a mentorship-driven
        community that takes you from zero to your first data job with real projects,
        mock interviews, and a proven roadmap.
      </p>
      <div class="reveal mt-9 flex flex-col items-center justify-center gap-3 sm:flex-row" style="animation-delay:240ms">
        <a href={site.surfalytics} target="_blank" rel="noopener" class="btn-accent text-base">
          Join Surfalytics
          <Icon name="arrow-up-right" size={18} />
        </a>
        <a href="#roadmap" class="btn-outline text-base">View the roadmap</a>
      </div>
    </div>
  </section>

  <!-- Key info -->
  <section class="shell py-4">
    <div class="mx-auto max-w-3xl space-y-5 border-t border-line pt-12 text-lg leading-relaxed text-ink-soft">
      {academyIntro.map((p) => <p>{p}</p>)}
    </div>
  </section>

  <!-- Outcomes / stats -->
  <section class="shell pt-16 md:pt-20">
    <div class="grid gap-6 sm:grid-cols-3">
      {
        stats.map((s) => (
          <div class="card p-8 text-center">
            <p class="font-display text-5xl font-extrabold text-navy">{s.value}</p>
            <p class="mt-3 text-ink-soft">{s.label}</p>
          </div>
        ))
      }
    </div>
  </section>

  <!-- Roadmap: tracks -->
  <section id="roadmap" class="shell scroll-mt-24 pt-20 md:pt-28">
    <SectionHeading
      eyebrow="Your roadmap"
      title="Start with onboarding, then pick your track"
    />
    <p class="mx-auto mt-5 max-w-2xl text-center text-lg leading-relaxed text-ink-soft">
      Every track follows the same proven structure — and leads to a specific,
      in-demand data role.
    </p>
    <div class="mt-12 grid gap-6 md:grid-cols-3">
      {
        tracks.map((track) => (
          <article class="card flex flex-col p-7">
            <span class="text-4xl" aria-hidden="true">{track.icon}</span>
            <h3 class="mt-4 text-xl font-bold text-navy">{track.label}</h3>
            <p class="mt-2 text-[0.975rem] leading-relaxed text-ink-soft">{track.summary}</p>
            <ul class="mt-5 space-y-2.5 border-t border-line pt-5">
              {track.modules.map((m) => (
                <li class="flex gap-2.5 text-sm text-ink/85">
                  <span class="mt-0.5 shrink-0 text-periwinkle"><Icon name="check" size={18} /></span>
                  {m}
                </li>
              ))}
            </ul>
          </article>
        ))
      }
    </div>
  </section>

  <!-- What every track includes -->
  <section class="shell pt-20 md:pt-28">
    <SectionHeading eyebrow="In every track" title="What's included" />
    <div class="mt-12 grid gap-6 sm:grid-cols-2 lg:grid-cols-4">
      {
        pillars.map((p) => (
          <div class="card p-6">
            <span class="text-3xl" aria-hidden="true">{p.icon}</span>
            <h3 class="mt-3 text-lg font-bold text-navy">{p.label}</h3>
            <p class="mt-2 text-sm leading-relaxed text-ink/70">{p.desc}</p>
          </div>
        ))
      }
    </div>
  </section>

  <!-- What you'll gain -->
  <section class="shell pt-20 md:pt-28">
    <div class="card p-8 md:p-12">
      <h2 class="text-2xl font-extrabold text-navy md:text-3xl">What you'll gain</h2>
      <ul class="mt-6 grid gap-4 sm:grid-cols-2">
        {
          gains.map((g) => (
            <li class="flex gap-3 text-[1.02rem] leading-relaxed text-ink/85">
              <span class="mt-0.5 shrink-0 text-periwinkle"><Icon name="check" size={22} /></span>
              {g}
            </li>
          ))
        }
      </ul>
    </div>
  </section>

  <!-- Salaries -->
  <section class="shell pt-16 md:pt-20">
    <div class="card p-8 md:p-12">
      <h2 class="text-2xl font-bold text-navy md:text-3xl">
        $120k CAD — average Data Analyst salary in 2024
      </h2>
      <div class="mt-8 grid gap-10 md:grid-cols-2">
        <div class="flex items-end justify-between gap-4" style="height: 240px;">
          {
            salaries.map((s) => (
              <div class="flex h-full flex-1 flex-col items-center justify-end gap-2">
                <span class="text-sm font-bold text-navy">{s.amount}</span>
                <div class="w-full rounded-t-lg bg-brand" style={`height: ${s.height}%`} />
                <span class="text-xs font-medium text-lilac">{s.level}</span>
              </div>
            ))
          }
        </div>
        <ul class="space-y-4 self-center">
          {
            salaryInsights.map((t) => (
              <li class="flex gap-3 text-[0.975rem] leading-relaxed text-ink/75">
                <span class="mt-0.5 shrink-0 text-periwinkle"><Icon name="check" size={20} /></span>
                {t}
              </li>
            ))
          }
        </ul>
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="shell pt-16 pb-4 md:pt-20">
    <div class="rounded-[1.5rem] bg-brand px-7 py-12 text-center text-white md:px-14 md:py-16">
      <h2 class="mx-auto max-w-2xl text-2xl font-extrabold leading-snug md:text-3xl">
        Ready to follow a full structured path?
      </h2>
      <p class="mx-auto mt-4 max-w-xl text-white/80">
        Join the Surfalytics community and start your roadmap today.
      </p>
      <div class="mt-8 flex flex-col items-center justify-center gap-3 sm:flex-row">
        <a href={site.surfalytics} target="_blank" rel="noopener" class="btn-accent text-base">
          Join Surfalytics
        </a>
        <a
          href={site.surfalyticsRoadmap}
          target="_blank"
          rel="noopener"
          class="btn-outline border-white/40 bg-white/10 text-base text-white hover:bg-white hover:text-paper"
        >
          Explore the full roadmap
        </a>
      </div>
    </div>
  </section>
</MarketingLayout>
