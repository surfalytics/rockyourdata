---
import MarketingLayout from "../layouts/MarketingLayout.astro";
import SectionHeading from "../components/SectionHeading.astro";
import Icon from "../components/Icon.astro";
import illustration from "../assets/illustrations/data-analysis.svg?url";
import {
  heroBullets,
  gains,
  roadmap,
  stats,
  skillGroups,
  salaries,
  salaryInsights,
  gainsIn3Months,
  pricing,
} from "../data/dataAnalyst";
---

<MarketingLayout
  title="Get a Data Analyst Job in 3 Months"
  description="Land your first Data Analyst job in 3 months — learn the modern data stack, build a portfolio, and get hired with Surfalytics."
>
  <!-- Hero -->
  <section class="bg-paper">
    <div class="shell grid items-center gap-12 pt-32 pb-16 md:grid-cols-2 md:pt-40 md:pb-24">
      <div class="reveal">
        <span class="eyebrow">Data career track</span>
        <h1 class="mt-3 text-4xl font-extrabold tracking-tight text-navy sm:text-5xl md:text-6xl">
          Get your first Data Analyst job in <span class="text-accent">3 months</span>
        </h1>
        <ul class="mt-7 space-y-3">
          {
            heroBullets.map((b) => (
              <li class="flex items-center gap-3 text-lg text-ink-soft">
                <span class="text-periwinkle"><Icon name="check" size={22} /></span>
                {b}
              </li>
            ))
          }
        </ul>
        <a href="#membership" class="btn-accent mt-9 text-base">Join now</a>
      </div>
      <img
        src={illustration}
        alt="Data analyst working with dashboards and charts"
        class="reveal mx-auto w-full max-w-md"
        style="animation-delay: 120ms"
      />
    </div>
  </section>

  <!-- Info -->
  <section class="shell py-16 text-center md:py-20">
    <h2 class="text-navy mx-auto max-w-3xl text-3xl font-extrabold md:text-4xl">
      The fastest way to get a Data Analyst job
    </h2>
    <p class="mx-auto mt-5 max-w-2xl text-lg leading-relaxed text-ink/80">
      Surfalytics is an immersive learning platform centered on practical experience.
      Our focused 20% effort delivers 80% of the results you need — making you job-ready
      for your first Data Analyst role in just 3 months.
    </p>
  </section>

  <!-- Here you will -->
  <section class="shell pb-4">
    <div class="card p-8 md:p-12">
      <h2 class="text-navy text-2xl font-extrabold md:text-3xl">Here you will:</h2>
      <ul class="mt-6 grid gap-4 sm:grid-cols-2">
        {
          gains.map((g) => (
            <li class="flex gap-3 text-[1.02rem] leading-relaxed text-ink/85">
              <span class="mt-0.5 shrink-0 text-periwinkle"><Icon name="check" size={22} /></span>
              {g}
            </li>
          ))
        }
      </ul>
    </div>
  </section>

  <!-- Roadmap -->
  <section class="shell pt-16 md:pt-24">
    <SectionHeading eyebrow="The path" title="How we get these results" />
    <div class="mt-12 grid gap-6 lg:grid-cols-3">
      {
        roadmap.map((phase, i) => (
          <div class="card flex flex-col p-7">
            <div class="flex items-baseline justify-between">
              <span class="eyebrow">{phase.phase}</span>
              <span class="font-display text-5xl font-extrabold text-fog">{i + 1}</span>
            </div>
            <h3 class="mt-1 text-2xl font-bold text-navy">{phase.title}</h3>
            <ol class="mt-5 space-y-5">
              {phase.steps.map((step, si) => (
                <li class="flex gap-4">
                  <span class="flex h-8 w-8 shrink-0 items-center justify-center rounded-full bg-navy text-sm font-bold text-white">
                    {si + 1}
                  </span>
                  <div>
                    <h4 class="font-semibold text-navy">{step.title}</h4>
                    <p class="mt-1 text-sm leading-relaxed text-ink/70">{step.description}</p>
                  </div>
                </li>
              ))}
            </ol>
          </div>
        ))
      }
    </div>
  </section>

  <!-- CTA band -->
  <section class="shell pt-16 md:pt-20">
    <div class="rounded-[2rem] bg-navy px-7 py-12 text-center text-white md:px-14">
      <h2 class="mx-auto max-w-3xl text-2xl font-extrabold leading-snug md:text-3xl">
        Join our community and get professional support on your journey to a successful
        Data Analyst career in Canada
      </h2>
      <a href="#membership" class="btn-accent mt-8 text-base">Reserve my spot</a>
    </div>
  </section>

  <!-- Stats -->
  <section class="shell pt-16 md:pt-20">
    <div class="grid gap-6 sm:grid-cols-3">
      {
        stats.map((s) => (
          <div class="card p-8 text-center">
            <p class="text-navy font-display text-5xl font-extrabold">{s.value}</p>
            <p class="mt-3 text-ink/75">{s.label}</p>
          </div>
        ))
      }
    </div>
  </section>

  <!-- Salaries -->
  <section class="shell pt-16 md:pt-20">
    <div class="card p-8 md:p-12">
      <h2 class="text-2xl font-bold text-navy md:text-3xl">
        $120k CAD — average Data Analyst salary in 2024
      </h2>
      <div class="mt-8 grid gap-10 md:grid-cols-2">
        <div class="flex items-end justify-between gap-4" style="height: 240px;">
          {
            salaries.map((s) => (
              <div class="flex h-full flex-1 flex-col items-center justify-end gap-2">
                <span class="text-sm font-bold text-navy">{s.amount}</span>
                <div
                  class="w-full rounded-t-lg bg-navy"
                  style={`height: ${s.height}%`}
                />
                <span class="text-xs font-medium text-lilac">{s.level}</span>
              </div>
            ))
          }
        </div>
        <ul class="space-y-4 self-center">
          {
            salaryInsights.map((t) => (
              <li class="flex gap-3 text-[0.975rem] leading-relaxed text-ink/75">
                <span class="mt-0.5 shrink-0 text-periwinkle"><Icon name="check" size={20} /></span>
                {t}
              </li>
            ))
          }
        </ul>
      </div>
    </div>
  </section>

  <!-- Role overview / skills -->
  <section class="shell pt-16 md:pt-20">
    <SectionHeading eyebrow="The role" title="Data Analyst role overview" />
    <p class="mx-auto mt-5 max-w-2xl text-center text-lg leading-relaxed text-ink/80">
      Data Analysts transform raw data into actionable insights that drive business
      decisions — collecting, processing, and analyzing large datasets to identify
      trends and patterns.
    </p>
    <div class="mt-12 grid gap-5 sm:grid-cols-2 lg:grid-cols-3">
      {
        skillGroups.map((group) => (
          <div class="card p-6">
            <h3 class="text-sm font-bold uppercase tracking-widest text-periwinkle">
              {group.heading}
            </h3>
            <ul class="mt-4 flex flex-wrap gap-2">
              {group.items.map((item) => (
                <li class="rounded-full bg-fog px-3 py-1 text-sm font-medium text-navy">
                  {item}
                </li>
              ))}
            </ul>
          </div>
        ))
      }
    </div>
    <div class="mt-10 text-center">
      <p class="text-ink/70">All of this is covered in the Surfalytics data analytics course.</p>
      <a
        href={pricing.coursePlaylist}
        target="_blank"
        rel="noopener"
        class="mt-3 inline-flex items-center gap-2 font-semibold text-periwinkle hover:text-navy"
      >
        Go to course — free
        <Icon name="arrow-up-right" size={18} />
      </a>
    </div>
  </section>

  <!-- Membership / pricing -->
  <section id="membership" class="shell scroll-mt-24 pt-16 md:pt-20">
    <div class="card grid gap-10 p-8 md:grid-cols-2 md:p-12">
      <div>
        <h2 class="text-navy text-2xl font-extrabold md:text-3xl">
          What you'll gain in just 3 months
        </h2>
        <ul class="mt-6 space-y-4">
          {
            gainsIn3Months.map((g) => (
              <li class="flex gap-3 text-[1.02rem] leading-relaxed text-ink/85">
                <span class="mt-0.5 shrink-0 text-periwinkle"><Icon name="check" size={22} /></span>
                {g}
              </li>
            ))
          }
        </ul>
      </div>

      <div class="flex flex-col rounded-2xl bg-navy p-8 text-white">
        <p class="text-sm font-semibold uppercase tracking-widest text-white/70">
          {pricing.label}
        </p>
        <p class="mt-3 text-xl font-medium text-white/60 line-through">{pricing.crossedPrice}</p>
        <p class="mt-1 text-4xl font-extrabold">{pricing.highlight}</p>
        <p class="mt-2 text-white/80">{pricing.then}</p>
        <div class="mt-7 flex flex-col gap-3">
          <a href={pricing.monthlyUrl} target="_blank" rel="noopener" class="btn-accent">
            Monthly payment
          </a>
          <a
            href={pricing.yearlyUrl}
            target="_blank"
            rel="noopener"
            class="btn-outline border-white/40 bg-white/10 text-white hover:bg-white hover:text-navy"
          >
            Yearly payment (59% off)
          </a>
        </div>
      </div>
    </div>
  </section>
</MarketingLayout>
