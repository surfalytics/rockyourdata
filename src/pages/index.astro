---
import MarketingLayout from "../layouts/MarketingLayout.astro";
import Hero from "../components/Hero.astro";
import SectionHeading from "../components/SectionHeading.astro";
import ServiceCard from "../components/ServiceCard.astro";
import InteractionCard from "../components/InteractionCard.astro";
import PartnerLogos from "../components/PartnerLogos.astro";
import SwagSection from "../components/SwagSection.astro";
import Icon from "../components/Icon.astro";
import { services, interactionModes } from "../data/services";
---

<MarketingLayout>
  <Hero />

  <!-- About band -->
  <section class="shell pt-20 md:pt-28">
    <div class="grid gap-8 border-t border-line pt-12 md:grid-cols-[0.9fr_1.1fr] md:gap-16">
      <div>
        <span class="eyebrow">Your hub for cloud analytics</span>
        <h2 class="mt-3 text-3xl font-extrabold tracking-tight text-navy md:text-4xl">
          Your data. Our skills.
        </h2>
      </div>
      <div class="text-lg leading-relaxed text-ink-soft">
        <p>
          Rock Your Data is a consulting and technology firm that delivers secure,
          scalable cloud analytics across North America.
        </p>
        <p class="mt-4">
          We help organizations make distinctive, lasting, and substantial
          improvements in their performance by leveraging their data and
          cutting-edge technology.
        </p>
        <a
          href="/about/"
          class="mt-6 inline-flex items-center gap-2 font-semibold text-periwinkle hover:text-navy"
        >
          Learn more about us
          <Icon name="arrow-right" size={18} />
        </a>
      </div>
    </div>
  </section>

  <!-- Services -->
  <section id="services" class="shell scroll-mt-24 pt-20 md:pt-28">
    <SectionHeading eyebrow="What we do" title="Our services" />
    <div class="mt-12 grid gap-6 md:gap-8">
      {services.map((service, i) => <ServiceCard service={service} reversed={i % 2 === 1} />)}
    </div>
  </section>

  <!-- How we interact -->
  <section class="shell pt-20 md:pt-28">
    <SectionHeading
      eyebrow="Engagement models"
      title="How we interact"
    />
    <div class="mt-12 grid gap-6 md:grid-cols-3">
      {interactionModes.map((m) => <InteractionCard {...m} />)}
    </div>
  </section>

  <PartnerLogos />

  <SwagSection />
</MarketingLayout>
