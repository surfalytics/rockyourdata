---
import MarketingLayout from "../layouts/MarketingLayout.astro";
import SectionHeading from "../components/SectionHeading.astro";
import InteractionCard from "../components/InteractionCard.astro";
import PlatformLogos from "../components/PlatformLogos.astro";
import FounderCard from "../components/FounderCard.astro";
import { values } from "../data/services";
import { founder } from "../data/founder";
---

<MarketingLayout
  title="About"
  description="Rock Your Data turns raw data into actionable insights, helping businesses make smarter, faster decisions with cloud analytics."
>
  <!-- Intro -->
  <section class="shell pt-20 pb-4 md:pt-28">
    <div class="mx-auto max-w-3xl text-center">
      <span class="eyebrow">About us</span>
      <h1 class="text-navy mt-3 text-4xl font-extrabold leading-tight md:text-5xl">
        Empowering business with data-driven solutions
      </h1>
      <p class="mt-6 text-lg leading-relaxed text-ink/80">
        At Rock Your Data, we specialize in transforming raw data into actionable
        insights, helping businesses make smarter, faster decisions. Our mission is
        to harness the power of data to drive meaningful change — unlocking new
        growth, streamlining operations, and innovating with confidence.
      </p>
    </div>
  </section>

  <!-- Values -->
  <section class="shell pt-16 md:pt-20">
    <SectionHeading eyebrow="What we stand for" title="Our values" />
    <div class="mt-12 grid gap-6 md:grid-cols-3">
      {values.map((v) => <InteractionCard {...v} />)}
    </div>
  </section>

  <FounderCard />

  <!-- Founder stats -->
  <section class="shell pt-12 md:pt-16">
    <div class="grid grid-cols-2 gap-4 lg:grid-cols-4">
      {
        founder.stats.map((s) => (
          <div class="card p-6 text-center">
            <p class="font-display text-4xl font-extrabold text-navy md:text-5xl">
              {s.value}
            </p>
            <p class="mt-2 text-sm text-ink-soft">{s.label}</p>
          </div>
        ))
      }
    </div>
  </section>

  <!-- Companies worked with -->
  <section class="shell pt-20 md:pt-28">
    <SectionHeading
      eyebrow="Track record"
      title="Companies Dmitry has worked with"
    />
    <div class="mx-auto mt-12 grid max-w-5xl grid-cols-3 gap-x-6 gap-y-8 sm:grid-cols-4 md:grid-cols-5 lg:grid-cols-6">
      {
        founder.companies.map((company) => (
          <div class="group flex flex-col items-center gap-2.5 text-center" title={company.name}>
            <span class="flex h-14 w-14 items-center justify-center rounded-xl border border-line bg-surface p-2.5">
              <img
                src={`https://icon.horse/icon/${company.domain}`}
                alt={`${company.name} logo`}
                width="40"
                height="40"
                loading="lazy"
                class="h-full w-full object-contain opacity-80 transition-opacity group-hover:opacity-100"
                onerror={`this.onerror=null;this.src='https://www.google.com/s2/favicons?domain=${company.domain}&sz=64'`}
              />
            </span>
            <span class="text-xs font-medium text-ink-soft transition-colors group-hover:text-navy">
              {company.name}
            </span>
          </div>
        ))
      }
    </div>
  </section>

  <!-- Books -->
  <section class="shell pt-20 md:pt-28">
    <SectionHeading eyebrow="Published author" title="10 technical books" />
    <div class="mx-auto mt-12 grid max-w-5xl grid-cols-2 gap-6 sm:grid-cols-3 lg:grid-cols-5">
      {
        founder.books.map((book) => (
          <figure class="group flex flex-col">
            <div class="overflow-hidden rounded-lg border border-line bg-surface shadow-lift">
              <img
                src={book.cover}
                alt={`Cover of ${book.title}`}
                loading="lazy"
                class="aspect-[2/3] w-full object-cover transition-transform duration-500 group-hover:scale-[1.04]"
              />
            </div>
            <figcaption class="mt-3">
              <p class="text-sm font-semibold leading-snug text-navy">{book.title}</p>
              <p class="mt-0.5 text-xs text-lilac">{book.year}</p>
            </figcaption>
          </figure>
        ))
      }
    </div>
  </section>

  <PlatformLogos heading="Platforms we're certified on" />
</MarketingLayout>
