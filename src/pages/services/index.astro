---
import MarketingLayout from "../../layouts/MarketingLayout.astro";
import SectionHeading from "../../components/SectionHeading.astro";
import InteractionCard from "../../components/InteractionCard.astro";
import PlatformLogos from "../../components/PlatformLogos.astro";
import Icon from "../../components/Icon.astro";
import FeatureIcon from "../../components/FeatureIcon.astro";
import { services, interactionModes } from "../../data/services";
import { site } from "../../data/site";
---

<MarketingLayout
  title="Services"
  description="Cloud analytics and data engineering services — modern data stack implementation, analytics audits, embedded experts, and data team development."
>
  <!-- Intro -->
  <section class="bg-paper">
    <div class="shell pt-32 pb-12 text-center md:pt-40 md:pb-16">
      <span class="eyebrow">Services</span>
      <h1 class="mx-auto mt-3 max-w-3xl text-4xl font-extrabold tracking-tight text-navy sm:text-5xl md:text-6xl">
        Data engineering and analytics, end to end
      </h1>
      <p class="mx-auto mt-6 max-w-2xl text-lg leading-relaxed text-ink-soft">
        From building your cloud platform to growing the team that runs it — we
        partner with you across the full analytics lifecycle.
      </p>
      <a href={`mailto:${site.email}`} class="btn-primary mt-9 text-base">
        Get a data services quote
        <Icon name="arrow-right" size={18} />
      </a>
    </div>
  </section>

  <!-- Service grid -->
  <section class="shell pt-8 md:pt-12">
    <div class="grid gap-6 md:grid-cols-2">
      {
        services.map((service) => (
          <a
            href={`/services/${service.slug}/`}
            class="card group flex flex-col p-7 transition-shadow hover:shadow-lift md:p-8"
          >
            <span class="inline-flex h-13 w-13 items-center justify-center rounded-xl bg-navy p-3 text-white">
              <FeatureIcon name={service.icon} size={26} />
            </span>
            <h2 class="mt-5 text-xl font-bold text-navy group-hover:text-periwinkle md:text-2xl">
              {service.title}
            </h2>
            <p class="mt-2 flex-1 text-ink-soft">{service.tagline}</p>
            <span class="mt-5 inline-flex items-center gap-2 text-sm font-semibold text-periwinkle">
              Explore service
              <Icon name="arrow-right" size={16} />
            </span>
          </a>
        ))
      }
    </div>
  </section>

  <!-- Engagement models -->
  <section class="shell pt-20 md:pt-28">
    <SectionHeading eyebrow="Engagement models" title="How we interact" />
    <div class="mt-12 grid gap-6 md:grid-cols-3">
      {interactionModes.map((m) => <InteractionCard {...m} />)}
    </div>
  </section>

  <PlatformLogos />
</MarketingLayout>
