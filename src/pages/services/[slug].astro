---
import { Image } from "astro:assets";
import MarketingLayout from "../../layouts/MarketingLayout.astro";
import FeatureIcon from "../../components/FeatureIcon.astro";
import Icon from "../../components/Icon.astro";
import { services } from "../../data/services";
import { site } from "../../data/site";

export function getStaticPaths() {
  return services.map((service, i) => ({
    params: { slug: service.slug },
    props: {
      service,
      others: services.filter((s) => s.slug !== service.slug),
    },
  }));
}

const { service, others } = Astro.props;
---

<MarketingLayout title={service.title} description={service.tagline}>
  <!-- Hero -->
  <section class="bg-paper">
    <div class="shell grid items-center gap-12 pt-32 pb-12 md:grid-cols-2 md:pt-40 md:pb-16">
      <div class="reveal">
        <a
          href="/services/"
          class="inline-flex items-center gap-1.5 text-sm font-semibold text-periwinkle hover:text-navy"
        >
          <span class="rotate-180"><Icon name="arrow-right" size={16} /></span>
          All services
        </a>
        <span
          class="mt-6 inline-flex h-14 w-14 items-center justify-center rounded-xl bg-navy text-white"
        >
          <FeatureIcon name={service.icon} size={30} />
        </span>
        <h1 class="mt-5 text-4xl font-extrabold tracking-tight text-navy sm:text-5xl">
          {service.title}
        </h1>
        <p class="mt-5 text-lg leading-relaxed text-ink-soft">{service.tagline}</p>
        <a href={`mailto:${site.email}`} class="btn-primary mt-8 text-base">
          Get a quote
          <Icon name="arrow-right" size={18} />
        </a>
      </div>
      <Image
        src={service.image}
        alt={service.imageAlt}
        widths={[400, 700, 1000]}
        sizes="(min-width: 768px) 36rem, 90vw"
        class="reveal aspect-[4/3] w-full rounded-xl border border-line object-cover"
        style="animation-delay: 120ms"
      />
    </div>
  </section>

  <!-- Overview -->
  <section class="shell pt-12 md:pt-16">
    <div class="mx-auto max-w-3xl border-t border-line pt-12">
      <span class="eyebrow">Overview</span>
      <div class="mt-4 space-y-5 text-lg leading-relaxed text-ink-soft">
        {service.overview.map((p) => <p>{p}</p>)}
      </div>
    </div>
  </section>

  <!-- Capabilities + deliverables -->
  <section class="shell pt-16 md:pt-20">
    <div class="mx-auto grid max-w-5xl gap-10 md:grid-cols-2">
      <div>
        <h2 class="text-2xl font-bold text-navy">What we do</h2>
        <ul class="mt-5 space-y-3">
          {
            service.capabilities.map((c) => (
              <li class="flex gap-3 text-[1.02rem] leading-relaxed text-ink/85">
                <span class="mt-0.5 shrink-0 text-periwinkle">
                  <Icon name="check" size={20} />
                </span>
                {c}
              </li>
            ))
          }
        </ul>
      </div>
      <div>
        <h2 class="text-2xl font-bold text-navy">What you get</h2>
        <ul class="mt-5 space-y-3">
          {
            service.deliverables.map((d) => (
              <li class="card flex items-start gap-3 p-4 text-[0.975rem] text-ink/85">
                <span class="mt-0.5 shrink-0 text-accent">
                  <Icon name="check" size={20} />
                </span>
                {d}
              </li>
            ))
          }
        </ul>
      </div>
    </div>
  </section>

  <!-- Process -->
  <section class="shell pt-16 md:pt-24">
    <div class="mx-auto max-w-5xl">
      <span class="eyebrow">How it works</span>
      <h2 class="mt-3 text-2xl font-bold text-navy md:text-3xl">Our engagement</h2>
      <ol class="mt-8 grid gap-6 sm:grid-cols-2 lg:grid-cols-4">
        {
          service.process.map((step, i) => (
            <li class="card p-6">
              <span class="font-display text-3xl font-extrabold text-fog">
                0{i + 1}
              </span>
              <h3 class="mt-2 text-lg font-bold text-navy">{step.title}</h3>
              <p class="mt-2 text-sm leading-relaxed text-ink/70">
                {step.description}
              </p>
            </li>
          ))
        }
      </ol>
    </div>
  </section>

  <!-- CTA band -->
  <section class="shell pt-16 md:pt-20">
    <div class="rounded-[1.5rem] bg-navy px-7 py-12 text-center text-white md:px-14 md:py-14">
      <h2 class="mx-auto max-w-2xl text-2xl font-extrabold leading-snug md:text-3xl">
        Ready to talk about {service.title.toLowerCase()}?
      </h2>
      <div class="mt-7 flex flex-col items-center justify-center gap-3 sm:flex-row">
        <a href={`mailto:${site.email}`} class="btn-accent text-base">Get a quote</a>
        <a
          href={site.calendly}
          target="_blank"
          rel="noopener"
          class="btn-outline border-white/40 bg-white/10 text-base text-white hover:bg-white hover:text-navy"
        >
          Book a discovery call
        </a>
      </div>
    </div>
  </section>

  <!-- Other services -->
  <section class="shell pt-16 md:pt-20">
    <h2 class="text-xl font-bold text-navy">Other services</h2>
    <div class="mt-6 grid gap-5 sm:grid-cols-3">
      {
        others.map((o) => (
          <a
            href={`/services/${o.slug}/`}
            class="card group flex items-center gap-4 p-5 transition-shadow hover:shadow-lift"
          >
            <span class="inline-flex h-11 w-11 shrink-0 items-center justify-center rounded-lg bg-fog text-navy transition-colors group-hover:bg-navy group-hover:text-white">
              <FeatureIcon name={o.icon} size={22} />
            </span>
            <span class="font-semibold text-navy group-hover:text-periwinkle">
              {o.title}
            </span>
          </a>
        ))
      }
    </div>
  </section>
</MarketingLayout>
