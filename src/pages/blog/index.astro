---
import { getCollection } from "astro:content";
import MarketingLayout from "../../layouts/MarketingLayout.astro";
import Icon from "../../components/Icon.astro";

const posts = (await getCollection("blog", ({ data }) => !data.draft)).sort(
  (a, b) => b.data.date.getTime() - a.data.date.getTime()
);
const fmt = (d: Date) =>
  new Intl.DateTimeFormat("en-US", { dateStyle: "long" }).format(d);
---

<MarketingLayout
  title="Blog"
  description="Insights on cloud analytics, data engineering, and building a data career from Rock Your Data."
>
  <section class="shell pt-20 pb-8 md:pt-28">
    <div class="mx-auto max-w-3xl text-center">
      <span class="eyebrow">Insights</span>
      <h1 class="text-navy mt-3 text-4xl font-extrabold leading-tight md:text-5xl">
        From the blog
      </h1>
      <p class="mt-6 text-lg leading-relaxed text-ink/80">
        Notes on cloud analytics, data engineering, and building a career in data.
      </p>
    </div>
  </section>

  <section class="shell pb-20">
    <div class="mx-auto grid max-w-4xl gap-5">
      {
        posts.map((post) => (
          <a
            href={`/blog/${post.id}/`}
            class="card group flex flex-col p-7 transition-shadow hover:shadow-lift"
          >
            <span class="flex items-center gap-3 text-xs font-semibold uppercase tracking-widest text-lilac">
              {post.data.category ?? "Article"}
              <span aria-hidden="true">·</span>
              <time>{fmt(post.data.date)}</time>
            </span>
            <h2 class="mt-3 text-2xl font-bold text-navy group-hover:text-periwinkle">
              {post.data.title}
            </h2>
            {post.data.description && (
              <p class="mt-2 text-ink/75">{post.data.description}</p>
            )}
            <span class="mt-4 inline-flex items-center gap-2 text-sm font-semibold text-periwinkle">
              Read article
              <Icon name="arrow-right" size={16} />
            </span>
          </a>
        ))
      }
    </div>
  </section>
</MarketingLayout>
