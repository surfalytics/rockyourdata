---
import MarketingLayout from "../layouts/MarketingLayout.astro";
import Icon from "../components/Icon.astro";
import { site } from "../data/site";
---

<MarketingLayout
  title="Contact"
  description="Get in touch with Rock Your Data — reach out by email about data engineering, AI, and space analytics."
>
  <section class="shell pt-20 pb-24 md:pt-28">
    <div class="mx-auto max-w-2xl text-center">
      <span class="eyebrow">Get in touch</span>
      <h1 class="text-navy mt-3 text-4xl font-extrabold leading-tight md:text-5xl">
        Let's start your data journey
      </h1>
      <p class="mt-6 text-lg leading-relaxed text-ink-soft">
        Have a project in mind or want to talk data engineering, AI, or space
        analytics? Drop us an email and we'll get back to you. 🚀
      </p>

      <a href={`mailto:${site.email}`} class="btn-primary mt-9 text-base">
        <Icon name="arrow-up-right" size={18} />
        {site.email}
      </a>
    </div>
  </section>
</MarketingLayout>
