---
import MarketingLayout from "../layouts/MarketingLayout.astro";
---

<MarketingLayout title="Page not found" noindex>
  <section class="shell flex min-h-[60vh] flex-col items-center justify-center py-24 text-center">
    <p class="font-display text-7xl font-extrabold text-navy">404</p>
    <h1 class="mt-4 text-2xl font-bold text-navy">This page took a different path.</h1>
    <p class="mt-3 max-w-md text-ink/70">
      The page you're looking for doesn't exist or may have moved.
    </p>
    <a href="/" class="btn-primary mt-8">Back to home</a>
  </section>
</MarketingLayout>
